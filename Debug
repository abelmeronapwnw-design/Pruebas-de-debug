end

local function addLineToDisplay(text, isSystem, isLimitWarning)
    if not isSystem and currentObjectsCount >= MAX_RESULTS then
        if not isLimitWarning then
            local warnMsg = "⚠️ Límite alcanzado (" .. MAX_RESULTS .. ")"
            addLineToDisplay(warnMsg, true, true)
        end
        return
    end
    if not isSystem then
        currentObjectsCount = currentObjectsCount + 1
    end
    table.insert(currentFullLog, text)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -10, 0, 18)
    lbl.BackgroundColor3 = isSystem and Color3.fromRGB(50, 50, 40) or Color3.fromRGB(25, 25, 35)
    lbl.BackgroundTransparency = 0.2
    lbl.Text = text
    lbl.TextColor3 = Color3.new(1, 1, 0.85)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 10
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = resultFrame
    local lblCorner = Instance.new("UICorner")
    lblCorner.CornerRadius = UDim.new(0, 3)
    lblCorner.Parent = lbl
    table.insert(currentLabels, lbl)
    task.wait()
    resultFrame.CanvasPosition = Vector2.new(0, resultFrame.CanvasSize.Y.Offset)
end

local function showTabResults(tabKey)
    local tab = tabsData[tabKey]
    if not tab then return end
    clearDisplay()
    activeTab = tabKey
    if tab.results then
        for _, line in ipairs(tab.fullLog) do
            local isSystem = (line:sub(1,1) == "✅" or line:sub(1,1) == "🔍" or line:sub(1,1) == "⚠️" or line:sub(1,3) == "📋" or line:sub(1,3) == "🧹")
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, -10, 0, 18)
            lbl.BackgroundColor3 = isSystem and Color3.fromRGB(50, 50, 40) or Color3.fromRGB(25, 25, 35)
            lbl.BackgroundTransparency = 0.2
            lbl.Text = line
            lbl.TextColor3 = Color3.new(1, 1, 0.85)
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 10
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Parent = resultFrame
            local lblCorner = Instance.new("UICorner")
            lblCorner.CornerRadius = UDim.new(0, 3)
            lblCorner.Parent = lbl
            table.insert(currentLabels, lbl)
        end
        currentFullLog = tab.fullLog
        currentObjectsCount = tab.objects
        task.wait()
        resultFrame.CanvasPosition = Vector2.new(0, resultFrame.CanvasSize.Y.Offset)
    else
        addLineToDisplay("📭 Sin resultados. Pulsa el botón para escanear.", true)
    end
end

local function copyCurrentDisplay()
    if #currentFullLog == 0 then
        addLineToDisplay("❌ No hay datos para copiar", true)
        return
    end
    local text = table.concat(currentFullLog, "\n")
    local success = pcall(function() setclipboard(text) end)
    if success then
        addLineToDisplay("📋 Copiado " .. #currentFullLog .. " líneas", true)
    else
        addLineToDisplay("❌ Error al copiar", true)
    end
end

local function clearActiveTab()
    if activeTab and tabsData[activeTab] then
        tabsData[activeTab].results = nil
        tabsData[activeTab].fullLog = nil
        tabsData[activeTab].objects = 0
        clearDisplay()
        addLineToDisplay("🧹 Resultados de la pestaña actual eliminados.", true)
    else
        addLineToDisplay("🧹 No hay pestaña activa o ya está limpia.", true)
    end
end

local function scanContainer(container, containerName, filter, tabKey)
    if scanning then
        addLineToDisplay("⚠️ Escaneo en curso, espera o usa Detener.", true)
        return
    end
    scanning = true
    stopRequested = false
    tabsData[tabKey].results = nil
    showTabResults(tabKey)
    addLineToDisplay("🔍 Escaneando " .. containerName .. " ...", true)
    local found = 0
    local scanned = 0
    local visited = {}
    local limitShown = false
    local function scan(obj, depth)
        if stopRequested then return end
        if depth > 25 then return end
        scanned = scanned + 1
        if scanned % 50 == 0 then task.wait(SCAN_PAUSE) end
        local fullName = obj:GetFullName()
        if visited[fullName] then return end
        visited[fullName] = true
        if IGNORE_NAMES[obj.Name] or IGNORE_CLASSES[obj.ClassName] then return end
        if filter(obj) then
            if currentObjectsCount < MAX_RESULTS then
                local icon = ""
                if obj:IsA("Tool") then icon = "🛠️ "
                elseif obj:IsA("RemoteEvent") then icon = "📡 "
                elseif obj:IsA("RemoteFunction") then icon = "📞 "
                elseif obj:IsA("ClickDetector") then icon = "🖱️ "
                elseif obj:IsA("ProximityPrompt") then icon = "📢 "
                elseif obj:IsA("BasePart") then icon = "🧩 "
                else icon = "📦 " end
                addLineToDisplay(icon .. fullName .. " (" .. obj.ClassName .. ")")
                found = found + 1
            elseif not limitShown then
                addLineToDisplay("⚠️ Límite alcanzado", true)
                limitShown = true
                return
            else
                return
            end
        end
        for _, child in ipairs(obj:GetChildren()) do
            if stopRequested then break end
            scan(child, depth + 1)
        end
    end
    pcall(scan, container, 0)
    if stopRequested then
        addLineToDisplay("⏹ Escaneo detenido.", true)
    end
    addLineToDisplay("✅ Escaneo completado. Encontrados: " .. found, true)
    tabsData[tabKey].fullLog = {}
    for _, line in ipairs(currentFullLog) do table.insert(tabsData[tabKey].fullLog, line) end
    tabsData[tabKey].objects = currentObjectsCount
    tabsData[tabKey].results = true
    scanning = false
end

local function isTool(obj) return obj:IsA("Tool") end
local function isWorkspaceObj(obj)
    return obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("ClickDetector") or obj:IsA("ProximityPrompt")
end
local function isRemote(obj) return obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") endlocal function scanPlayer(tabKey)
    if scanning then
        addLineToDisplay("⚠️ Escaneo en curso.", true)
        return
    end
    scanning = true
    stopRequested = false
    tabsData[tabKey].results = nil
    showTabResults(tabKey)
    addLineToDisplay("🔍 Escaneando Player...", true)
    local found = 0
    local visited = {}
    local limitShown = false
    local function scanObj(obj)
        if stopRequested then return end
        if visited[obj] then return end
        visited[obj] = true
        if IGNORE_NAMES[obj.Name] or IGNORE_CLASSES[obj.ClassName] then return end
        local relevant = (obj:IsA("Tool") or obj.Name == "leaderstats" or (obj:IsA("NumberValue") and obj.Parent == LocalPlayer))
        if relevant then
            if currentObjectsCount < MAX_RESULTS then
                local icon = obj:IsA("Tool") and "🛠️ " or "💰 "
                addLineToDisplay(icon .. obj:GetFullName() .. " (" .. obj.ClassName .. ")")
                found = found + 1
            elseif not limitShown then
                addLineToDisplay("⚠️ Límite alcanzado", true)
                limitShown = true
                return
            end
        end
        for _, child in ipairs(obj:GetChildren()) do
            if stopRequested then break end
            scanObj(child)
        end
    end
    pcall(scanObj, LocalPlayer.Backpack)
    if LocalPlayer.Character then pcall(scanObj, LocalPlayer.Character) end
    pcall(scanObj, LocalPlayer)
    if stopRequested then addLineToDisplay("⏹ Detenido.", true) end
    addLineToDisplay("✅ Player finalizado. Encontrados: " .. found, true)
    tabsData[tabKey].fullLog = {}
    for _, line in ipairs(currentFullLog) do table.insert(tabsData[tabKey].fullLog, line) end
    tabsData[tabKey].objects = currentObjectsCount
    tabsData[tabKey].results = true
    scanning = false
end

local function scanExtra(tabKey)
    if scanning then
        addLineToDisplay("⚠️ Escaneo en curso.", true)
        return
    end
    scanning = true
    stopRequested = false
    tabsData[tabKey].results = nil
    showTabResults(tabKey)
    addLineToDisplay("🔍 Escaneando Extra (StarterGui, etc)...", true)
    local containers = {
        game:GetService("StarterGui"),
        game:GetService("StarterPack"),
        game:GetService("Lighting"),
        LocalPlayer.PlayerGui
    }
    local total = 0
    local limitShown = false
    for _, cont in ipairs(containers) do
        if stopRequested then break end
        if cont then
            addLineToDisplay("--- " .. cont.Name .. " ---", true)
            local function scanAll(obj, depth)
                if stopRequested then return end
                if depth > 20 then return end
                task.wait()
                local full = obj:GetFullName()
                if IGNORE_NAMES[obj.Name] or IGNORE_CLASSES[obj.ClassName] then return end
                if currentObjectsCount < MAX_RESULTS then
                    addLineToDisplay("📦 " .. full .. " (" .. obj.ClassName .. ")")
                    total = total + 1
                elseif not limitShown then
                    addLineToDisplay("⚠️ Límite alcanzado", true)
                    limitShown = true
                    return
                end
                for _, child in ipairs(obj:GetChildren()) do
                    if stopRequested then break end
                    scanAll(child, depth + 1)
                end
            end
            scanAll(cont, 0)
        end
    end
    if stopRequested then addLineToDisplay("⏹ Detenido.", true) end
    addLineToDisplay("✅ Extra completado. Mostrados: " .. total, true)
    tabsData[tabKey].fullLog = {}
    for _, line in ipairs(currentFullLog) do table.insert(tabsData[tabKey].fullLog, line) end
    tabsData[tabKey].objects = currentObjectsCount
    tabsData[tabKey].results = true
    scanning = false
end

